modules = ["python-3.12", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full", "libGL", "libGLU", "openssl", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Auto Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m MukeshRobot"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Auto Push to GitHub"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash auto_push.sh"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
ENV = "True"
SUPPORT_CHAT = "worldwide_friend_zone"
WORKERS = "8"
TEMP_DOWNLOAD_DIRECTORY = "./"
ALLOW_CHATS = "True"
STRICT_GBAN = "True"
INFOPIC = "True"
DEL_CMDS = "False"
ALLOW_EXCL = "False"
