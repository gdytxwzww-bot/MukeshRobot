# ============================================================
# MukeshRobot — Complete Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
# All variables marked REQUIRED must be set before the bot starts.
# ============================================================

# ─── CORE TELEGRAM CREDENTIALS ──────────────────────────────
# Required | Get from https://my.telegram.org/apps
API_ID=

# Required | Get from https://my.telegram.org/apps
API_HASH=

# Required | Get your bot token from @BotFather on Telegram
TOKEN=

# Required | Your Telegram user ID as an integer (e.g. 123456789)
OWNER_ID=

# ─── ENABLE ENVIRONMENT VARIABLES ───────────────────────────
# Required | Must be set to "True" to load config from env vars (not config.py)
ENV=True

# ─── DATABASES ──────────────────────────────────────────────
# Required | PostgreSQL connection URL
# Railway: automatically set when PostgreSQL service is added
# Format:  postgresql://user:password@host:port/dbname
DATABASE_URL=

# Required | MongoDB connection URI
# Get a free cluster at https://cloud.mongodb.com
# Format:  mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGO_DB_URI=

# ─── BOT IDENTITY ───────────────────────────────────────────
# Required | Telegram channel/group ID for logging bot events (e.g. -1001234567890)
EVENT_LOGS=

# Required | Telegram username of your support group (without @)
# Default: worldwide_friend_zone
SUPPORT_CHAT=worldwide_friend_zone

# Required | Direct image URL shown on /start command (Telegraph link recommended)
START_IMG=

# ─── OPTIONAL API KEYS ──────────────────────────────────────
# Optional | Currency conversion API key from https://www.alphavantage.co/support/#api-key
CASH_API_KEY=

# Optional | Timezone API key from https://timezonedb.com/api
TIME_API_KEY=

# Optional | Ginger spell-check API key (default built-in key provided)
GINGER_API_KEY=6ae0c3a0-afdc-4532-a810-82ded0054236

# ─── USER ROLES (space-separated Telegram user IDs) ─────────
# Optional | Super admin / sudo user IDs (space-separated integers)
DRAGONS=

# Optional | Developer user IDs (space-separated integers)
# Default: 2145093972
DEV_USERS=2145093972

# Optional | Support/demon user IDs (space-separated integers)
DEMONS=

# Optional | Tiger-level user IDs (space-separated integers)
TIGERS=

# Optional | Whitelisted user IDs (space-separated integers)
WOLVES=

# Optional | Blacklisted chat IDs (space-separated integers)
BL_CHATS=

# ─── FEATURE FLAGS ──────────────────────────────────────────
# Optional | Allow ! as a command prefix alongside /
# Default: False
ALLOW_EXCL=False

# Optional | Allow bot to operate in non-private chats
# Default: True
ALLOW_CHATS=True

# Optional | Delete command messages from users without permission
# Default: False
DEL_CMDS=False

# Optional | Show bot info picture
# Default: True
INFOPIC=True

# Optional | Enforce global bans (gban) strictly
# Default: True
STRICT_GBAN=True

# ─── MODULE LOADING ─────────────────────────────────────────
# Optional | Space-separated list of extra modules to force-load
LOAD=

# Optional | Space-separated list of modules to skip loading
NO_LOAD=

# ─── PERFORMANCE ────────────────────────────────────────────
# Optional | Number of worker threads for the bot
# Default: 8
WORKERS=8

# Optional | Temporary download directory for media files
# Default: ./
TEMP_DOWNLOAD_DIRECTORY=./
